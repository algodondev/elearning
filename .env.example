NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DB_HOST=localhost
DB_PORT=5433
DB_NAME=elearning
DB_USER=elearning
DB_PASSWORD=replace-with-a-local-password
DB_SSL=false
# Required only when DB_SSL=true. Use an escaped PEM value with \n line breaks.
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
DB_LOGGING=false

# Optional override for the three accounts created by npm run seed.
SEED_PASSWORD=DevOnly123!

JWT_SECRET=replace-with-at-least-32-characters
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
ALERT_CRON=0 0 2 * * *
