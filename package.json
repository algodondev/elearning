{
  "name": "elearning",
  "version": "0.0.1",
  "description": "Corporate e-learning REST API for courses, assessments, certifications and compliance",
  "author": "ESEN",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"docs/**/*.md\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"docs/**/*.md\" \"*.md\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test,scripts}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test,scripts}/**/*.ts\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --config ./test/jest-coverage.json --coverage --runInBand",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/InitialSchema -d src/database/data-source/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/database/data-source/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/data-source/data-source.ts",
    "seed": "ts-node src/database/seeds/development.seed/development.seed.ts",
    "openapi:generate": "ts-node scripts/generate-openapi.ts",
    "openapi:test": "npm run test:e2e -- --runInBand test/openapi.e2e-spec.ts",
    "postman:generate": "ts-node scripts/generate-postman.ts",
    "postman:test": "docker run --rm --network elearning-network -v \"$PWD/postman:/etc/newman\" postman/newman:alpine run corporate-elearning.postman_collection.json --environment local.postman_environment.json --env-var baseUrl=http://api:3000/api/v1 --bail",
    "report:benchmark": "ts-node scripts/benchmark-compliance-report.ts",
    "verify": "npm run format:check && npm run lint:check && npm run build && npm test && npm run test:e2e && npm run test:cov && npm run openapi:test && npm audit --audit-level=high"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.3.0",
    "joi": "^18.2.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.module.ts",
      "!main.ts",
      "!database/migrations/**",
      "!database/data-source/**",
      "!database/seeds/**",
      "!**/*.entity.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
