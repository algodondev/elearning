              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@elearning.local\",\n  \"password\": \"DevOnly123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
