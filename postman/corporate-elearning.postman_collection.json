          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('database is up', () => pm.expect(pm.response.json().database).to.eql('up'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin login",
